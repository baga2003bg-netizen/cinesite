            </div>
            <button type="submit" className="w-full py-2 bg-indigo-600 text-white rounded-lg font-bold">Save Product</button>
          </form>
        </div>

        <div className="lg:col-span-3 bg-white dark:bg-gray-800 rounded-2xl border dark:border-gray-700 overflow-hidden shadow-sm">
          <div className="overflow-x-auto">
            <table className="w-full text-left">
              <thead>
                <tr className="bg-gray-50 dark:bg-gray-800/50 text-gray-500 text-sm">
                  <th className="p-4">Product</th>
                  <th className="p-4">Pricing</th>
                  <th className="p-4">Stock</th>
                  <th className="p-4 text-right">Actions</th>
                </tr>
              </thead>
              <tbody className="divide-y dark:divide-gray-700">
                {inventory.map(item => (
                  <tr key={item.id} className="text-sm hover:bg-gray-50 dark:hover:bg-gray-800/50">
                    <td className="p-4">
                      <div className="font-bold">{item.name}</div>
                      <div className="text-xs text-gray-400">{item.sku} • {item.category}</div>
                    </td>
                    <td className="p-4">
                      <div className="text-indigo-500 font-bold">{formatCurrency(item.priceSell)}</div>
                      <div className="text-xs text-gray-400">Buy: {formatCurrency(item.priceBuy)}</div>
                    </td>
                    <td className="p-4">
                      <div className="flex items-center gap-3">
                        <span className={`px-2 py-1 rounded font-bold min-w-[30px] text-center ${item.stock <= item.minStock ? 'bg-red-100 text-red-600' : 'bg-green-100 text-green-600'}`}>
                          {item.stock}
                        </span>
                        <div className="flex gap-1">
                          <button onClick={() => handleUpdateStock(item.id, 1)} className="p-1 hover:bg-gray-200 dark:hover:bg-gray-700 rounded transition-colors"><Plus size={14}/></button>
                          <button 
                            onClick={() => {
