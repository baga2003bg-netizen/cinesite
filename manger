            n.type === 'warning' ? 'bg-amber-50 border-amber-200 text-amber-800' :
            n.type === 'success' ? 'bg-emerald-50 border-emerald-200 text-emerald-800' :
            'bg-white dark:bg-gray-800 border-gray-100 dark:border-gray-700 text-gray-800 dark:text-gray-100'
          }`}>
            <div className="mt-0.5">
              {n.type === 'error' ? <AlertCircle size={20}/> : n.type === 'warning' ? <AlertTriangle size={20}/> : <Info size={20}/>}
            </div>
            <div className="flex-1">
              <div className="font-black text-sm">{n.title}</div>
              <div className="text-xs opacity-80 mt-1 leading-tight">{n.message}</div>
            </div>
          </div>
        ))}
      </div>

      <div className="flex h-screen overflow-hidden">
        <aside className="w-72 bg-white dark:bg-gray-900 border-r dark:border-gray-800 flex flex-col hidden md:flex shrink-0">
          <div className="p-10 text-3xl font-black bg-clip-text text-transparent bg-gradient-to-r from-indigo-500 to-purple-500">RiseStock</div>
          <nav className="flex-1 px-6 space-y-3">
            {[ 
              { id: 'dashboard', icon: LayoutDashboard, label: 'Dashboard' }, 
              { id: 'pos', icon: ShoppingBag, label: 'Store POS' }, 
              { id: 'inventory', icon: Package, label: 'Inventory' } 
            ].map(item => (
              <button key={item.id} onClick={() => setActiveTab(item.id)} className={`w-full flex items-center gap-4 px-5 py-4 rounded-2xl transition-all font-bold text-sm ${activeTab === item.id ? 'bg-indigo-600 text-white shadow-xl shadow-indigo-500/30' : 'text-gray-500 hover:bg-gray-100 dark:hover:bg-gray-800'}`}><item.icon size={20}/>{item.label}</button>
            ))}
          </nav>
          <div className="p-8 border-t dark:border-gray-800 text-xs text-gray-500">Version 2.0 • Bulk Tools Ready</div>
        </aside>

        <main className="flex-1 flex flex-col overflow-hidden">
          <header className="h-20 flex items-center justify-between px-10 bg-white/50 dark:bg-gray-900/50 backdrop-blur-md border-b dark:border-gray-800 shrink-0">
            <div className="font-black text-sm tracking-widest uppercase opacity-40">{activeTab}</div>
            <div className="flex items-center gap-4">
               {lowStockItems.length > 0 && (
                 <div className="px-4 py-2 bg-red-100 dark:bg-red-900/30 text-red-600 dark:text-red-400 rounded-full text-xs font-black animate-pulse flex items-center gap-2">
                   <AlertTriangle size={14}/> {lowStockItems.length} Warnings
                 </div>
               )}
               <button onClick={() => setTheme(theme === 'dark' ? 'light' : 'dark')} className="p-3 rounded-2xl hover:bg-gray-100 dark:hover:bg-gray-800 transition-all border dark:border-gray-700">
                 {theme === 'dark' ? <Sun size={20}/> : <Moon size={20}/>}
               </button>
            </div>
          </header>
          <div className="flex-1 overflow-y-auto p-6 md:p-10">
            <div className="max-w-7xl mx-auto h-full">
              {activeTab === 'dashboard' && <DashboardView />}
              {activeTab === 'pos' && <POSView />}
              {activeTab === 'inventory' && <InventoryView />}
            </div>
          </div>
        </main>
      </div>
    </div>
  );
}
