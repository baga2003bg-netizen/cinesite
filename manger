              </div>
            </div>
          </div>
        </div>
      )}
    </div>
  );

  const POSView = () => (
    <div className="h-full flex flex-col lg:flex-row gap-6 animate-in fade-in duration-300">
      <div className="flex-1 flex flex-col">
        <div className="mb-4 relative">
          <Search className="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400" size={18} />
          <input className="w-full pl-10 pr-4 py-3 bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-2xl" placeholder="Search inventory..." />
        </div>
        <div className="grid grid-cols-2 md:grid-cols-4 gap-4 overflow-y-auto pr-2">
          {inventory.map(p => (
            <button key={p.id} onClick={() => {
              if (p.stock <= 0) { addNotification("Out of Stock", `${p.name} is unavailable.`, "error"); return; }
              setCart(prev => {
                const ex = prev.find(i => i.id === p.id);
                if (ex) return prev.map(i => i.id === p.id ? {...i, qty: i.qty + 1} : i);
                return [...prev, {...p, qty: 1, cost: p.priceBuy}];
              });
            }} className="p-4 bg-white dark:bg-gray-800 rounded-2xl border dark:border-gray-700 text-left hover:border-indigo-500 transition-all active:scale-95 group relative">
              <div className="text-[10px] font-bold text-indigo-500 uppercase tracking-widest">{p.brand}</div>
              <div className="font-bold text-sm line-clamp-2 h-10 mt-1">{p.name}</div>
              <div className="mt-4 flex justify-between items-center">
                <span className="font-black text-lg">{formatCurrency(p.priceSell)}</span>
                <span className={`text-[10px] px-2 py-1 rounded-full font-bold ${p.stock <= p.minStock ? 'bg-red-100 text-red-600' : 'bg-gray-100 dark:bg-gray-700 text-gray-500'}`}>{p.stock} units</span>
              </div>
            </button>
          ))}
        </div>
      </div>
      <div className="w-full lg:w-96 bg-white dark:bg-gray-800 border dark:border-gray-700 rounded-3xl flex flex-col shadow-xl overflow-hidden h-[600px] lg:h-auto">
        <div className="p-6 font-bold border-b dark:border-gray-700 flex items-center justify-between">
          <div className="flex items-center gap-2"><ShoppingCart size={20}/> Checkout</div>
          {cart.length > 0 && <button onClick={() => setCart([])} className="text-xs text-red-500 font-bold hover:underline">Clear</button>}
        </div>
        <div className="flex-1 overflow-y-auto p-6 space-y-4">
          {cart.map(item => (
            <div key={item.id} className="flex justify-between items-center animate-in slide-in-from-left duration-200">
              <div className="flex-1">
                <div className="text-sm font-bold truncate pr-2">{item.name}</div>
                <div className="text-xs text-gray-400">{formatCurrency(item.priceSell)} x {item.qty}</div>
              </div>
              <div className="flex items-center gap-3">
                <div className="font-black text-sm">{formatCurrency(item.priceSell * item.qty)}</div>
                <button onClick={() => setCart(cart.filter(i => i.id !== item.id))} className="text-gray-300 hover:text-red-400 p-1"><X size={16}/></button>
              </div>
            </div>
          ))}
          {cart.length === 0 && (
            <div className="h-full flex flex-col items-center justify-center text-gray-400 text-center opacity-30">
              <ShoppingCart size={48} className="mb-2" />
              <p>Scan items to begin</p>
            </div>
          )}
        </div>
        <div className="p-6 bg-gray-50 dark:bg-gray-900 border-t dark:border-gray-700 space-y-4">
          <div className="flex justify-between text-sm text-gray-500"><span>Items Total</span><span>{formatCurrency(cart.reduce((s,i) => s + (i.priceSell * i.qty), 0))}</span></div>
          <div className="flex justify-between font-black text-2xl border-t dark:border-gray-800 pt-4"><span>Total</span><span className="text-indigo-600 dark:text-indigo-400">{formatCurrency(cart.reduce((s,i) => s + (i.priceSell * i.qty), 0))}</span></div>
          <button onClick={() => handleCheckout('Card')} disabled={cart.length === 0} className="w-full py-4 bg-indigo-600 text-white rounded-2xl font-bold shadow-lg shadow-indigo-500/30 disabled:opacity-50 hover:bg-indigo-700 transition-all flex items-center justify-center gap-2">
            <CreditCard size={20}/> Pay & Print Receipt
          </button>
        </div>
      </div>
    </div>
  );

  const DashboardView = () => (
    <div className="space-y-6">
       <div className="grid grid-cols-1 md:grid-cols-4 gap-6">
         <div className="bg-white dark:bg-gray-800 p-6 rounded-3xl border dark:border-gray-700 shadow-sm">
           <div className="text-gray-400 text-xs font-bold uppercase tracking-widest mb-1">Total Revenue</div>
           <div className="text-3xl font-black">{formatCurrency(totalRevenue)}</div>
         </div>
         <div className="bg-white dark:bg-gray-800 p-6 rounded-3xl border dark:border-gray-700 shadow-sm">
           <div className="text-gray-400 text-xs font-bold uppercase tracking-widest mb-1">Stock Value</div>
           <div className="text-3xl font-black">{formatCurrency(inventoryValue)}</div>
         </div>
         <div className="bg-white dark:bg-gray-800 p-6 rounded-3xl border dark:border-gray-700 shadow-sm">
           <div className="text-gray-400 text-xs font-bold uppercase tracking-widest mb-1">Low Stock Alerts</div>
           <div className={`text-3xl font-black ${lowStockItems.length > 0 ? 'text-red-500' : 'text-green-500'}`}>{lowStockItems.length}</div>
         </div>
         <div className="bg-white dark:bg-gray-800 p-6 rounded-3xl border dark:border-gray-700 shadow-sm">
           <div className="text-gray-400 text-xs font-bold uppercase tracking-widest mb-1">Store Expenses</div>
           <div className="text-3xl font-black text-red-500">{formatCurrency(totalExpenses)}</div>
