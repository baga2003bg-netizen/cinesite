// --- MAIN APP ---

export default function App() {
  const [theme, setTheme] = useState('dark');
  const [activeTab, setActiveTab] = useState('dashboard');
  const [isMobileMenuOpen, setIsMobileMenuOpen] = useState(false);
  
  const [inventory, setInventory] = useState(INITIAL_INVENTORY);
  const [sales, setSales] = useState(INITIAL_SALES);
  const [expenses, setExpenses] = useState(INITIAL_EXPENSES);
  const [cart, setCart] = useState([]);
  const [discount, setDiscount] = useState(0);
  const [notifications, setNotifications] = useState([]);
  const [showImportModal, setShowImportModal] = useState(false);

  const fileInputRef = useRef(null);

  // AI Specific State
  const [isAiLoading, setIsAiLoading] = useState(false);
  const [aiReport, setAiReport] = useState("");

  // Analytics
  const totalRevenue = useMemo(() => sales.reduce((sum, sale) => sum + sale.total, 0), [sales]);
  const totalExpenses = useMemo(() => expenses.reduce((sum, exp) => sum + exp.amount, 0), [expenses]);
  const inventoryValue = useMemo(() => inventory.reduce((sum, item) => sum + (item.priceBuy * item.stock), 0), [inventory]);
  const lowStockItems = useMemo(() => inventory.filter(item => item.stock <= item.minStock), [inventory]);

  const addNotification = (title, message, type = 'info') => {
    const id = generateId();
    setNotifications(prev => [{ id, title, message, type }, ...prev]);
    setTimeout(() => setNotifications(prev => prev.filter(n => n.id !== id)), 5000);
  };

  // --- HANDLERS ---
  const handleAddProduct = (e) => {
    e.preventDefault();
    const formData = new FormData(e.target);
    const newProduct = {
      id: generateId(),
      name: formData.get('name'),
      category: formData.get('category'),
      brand: formData.get('brand'),
      sku: formData.get('sku') || `SKU-${Date.now()}`,
      priceBuy: parseFloat(formData.get('priceBuy')),
      priceSell: parseFloat(formData.get('priceSell')),
      stock: parseInt(formData.get('stock')),
      minStock: parseInt(formData.get('minStock')),
      supplier: formData.get('supplier'),
    };
    setInventory([...inventory, newProduct]);
    addNotification("Product Added", `${newProduct.name} saved.`, "success");
    e.target.reset();
  };

  const handleUpdateStock = (id, amount) => {
    setInventory(prev => prev.map(item => {
      if (item.id === id) {
        const newStock = item.stock + amount;
        if (newStock <= item.minStock) addNotification("Low Stock!", `${item.name} is now low.`, "warning");
        return { ...item, stock: newStock };
      }
      return item;
    }));
    addNotification("Stock Updated", "Inventory adjusted.", "success");
  };

  const handleDeleteProduct = (id) => {
    if (confirm("Delete this product?")) {
      setInventory(prev => prev.filter(p => p.id !== id));
      addNotification("Product Deleted", "Item removed.", "info");
    }
  };

  const handleCheckout = (paymentMethod) => {
    if (cart.length === 0) return;
    const subtotal = cart.reduce((sum, item) => sum + (item.priceSell * item.qty), 0);
    const total = subtotal - (subtotal * discount / 100);
    const newSale = { id: generateId(), date: new Date().toISOString(), items: [...cart], total, paymentMethod };

    setInventory(prev => prev.map(invItem => {
      const cartItem = cart.find(c => c.id === invItem.id);
      if (cartItem) {
        const newStock = invItem.stock - cartItem.qty;
        if (newStock <= invItem.minStock) addNotification("Low Stock!", `${invItem.name} is low.`, "warning");
        return { ...invItem, stock: newStock };
      }
      return invItem;
    }));

    setSales(prev => [newSale, ...prev]);
    setCart([]);
    addNotification("Sale Complete", "Transaction recorded.", "success");
  };

  // --- EXCEL/CSV IMPORT FEATURE ---
  const downloadTemplate = () => {
    const headers = "Name,Category,Brand,SKU,BuyPrice,SellPrice,Stock,MinStock,Supplier\n";
    const example = "Example TV,Electronics,LG,SKU001,1000,1500,20,5,LG Global\nExample Fridge,Kitchen,Samsung,SKU002,1200,2000,10,2,Samsung Home";
    const blob = new Blob([headers + example], { type: 'text/csv' });
    const url = window.URL.createObjectURL(blob);
    const a = document.createElement('a');
    a.href = url;
    a.download = 'risestock_inventory_template.csv';
    a.click();
    addNotification("Template Ready", "Check your downloads folder.", "info");
  };

  const handleFileUpload = (e) => {
    const file = e.target.files[0];
    if (!file) return;

    const reader = new FileReader();
    reader.onload = (event) => {
      try {
        const text = event.target.result;
        const rows = text.split('\n').filter(row => row.trim() !== '');
        if (rows.length < 2) throw new Error("File is empty or missing data.");

        const headers = rows[0].split(',').map(h => h.trim().toLowerCase());
        
        const newItems = rows.slice(1).map((row, index) => {
          const values = row.split(',').map(v => v.trim());
          const item = {};
          headers.forEach((header, i) => {
            item[header] = values[i];
          });

          // Validation and Mapping
          return {
            id: generateId(),
            name: item.name || `Imported Item ${index + 1}`,
            category: item.category || 'General',
            brand: item.brand || 'Unknown',
            sku: item.sku || `SKU-${Date.now()}-${index}`,
            priceBuy: parseFloat(item.buyprice) || 0,
            priceSell: parseFloat(item.sellprice) || 0,
            stock: parseInt(item.stock) || 0,
            minStock: parseInt(item.minstock) || 0,
            supplier: item.supplier || 'N/A'
          };
        });

        setInventory(prev => [...prev, ...newItems]);
        addNotification("Import Successful", `${newItems.length} products imported.`, "success");
        setShowImportModal(false);
      } catch (err) {
        addNotification("Import Failed", "Ensure your CSV format matches the template.", "error");
        console.error(err);
      }
    };
    reader.readAsText(file);
    e.target.value = null; // Reset input
